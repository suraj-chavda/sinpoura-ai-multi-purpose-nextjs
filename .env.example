# https://authjs.dev
AUTH_SECRET=

# App URL (e.g. http://localhost:3000) — used by Auth.js
AUTH_URL=http://localhost:3000

# Canonical site URL for SEO (Open Graph, sitemap, robots). Defaults to AUTH_URL if unset.
# Production example: https://your-domain.com
SITE_URL=

MONGODB_URI=mongodb://127.0.0.1:27017/sinpoura

# OpenAI (used by @xoin/xoin-js)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Anthropic (optional; used by @xoin/xoin-js when set)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
